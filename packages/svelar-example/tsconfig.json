{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "strict": true,
    "moduleResolution": "bundler",
    "paths": {
      "$lib": ["./src/lib"],
      "$lib/*": ["./src/lib/*"],
      "svelar": ["../svelar/src/index.ts"],
      "svelar/*": ["../svelar/src/*/index.ts"]
    }
  }
}
