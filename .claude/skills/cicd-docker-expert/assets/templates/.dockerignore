# .dockerignore - Optimize build context and prevent sensitive files

# Version control
.git
.gitignore
.gitattributes
.github

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json  # Include only if not using in build
pnpm-debug.log*

# Build artifacts
dist
build
.next
.nuxt
out
.output
.cache

# Environment files (CRITICAL - Never include secrets)
.env
.env.*
.env.local
.env.development
.env.production
!.env.example

# Secrets and credentials (CRITICAL)
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
credentials.json
secrets/
**/*password*
**/*secret*
**/*token*
**/*private*

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Testing
coverage
.nyc_output
test
tests
**/*.test.js
**/*.spec.js
**/*.test.ts
**/*.spec.ts
jest.config.js
vitest.config.ts

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
.circleci
azure-pipelines.yml
Jenkinsfile

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
*.md
!README.md  # Include README if needed
docs
LICENSE

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Temporary files
tmp
temp
*.tmp
*.temp

# Archives
*.zip
*.tar
*.tar.gz
*.rar

# Media files (if not needed)
*.mp4
*.mov
*.avi
*.wmv
