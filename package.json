{
  "name": "svelar-monorepo",
  "private": true,
  "workspaces": [
    "packages/svelar",
    "packages/svelar-datatable",
    "packages/svelar-stripe",
    "packages/svelar-media",
    "packages/svelar-social-auth",
    "packages/svelar-two-factor",
    "packages/svelar-settings",
    "packages/svelar-comments",
    "packages/svelar-activity-log",
    "packages/svelar-backup",
    "packages/svelar-charts",
    "packages/svelar-tags",
    "packages/svelar-impersonate",
    "packages/svelar-sitemap",
    "packages/svelar-vscode"
  ],
  "scripts": {
    "build": "npm run build -w packages/svelar",
    "dev": "npm run dev -w packages/svelar",
    "test": "npm run test -w packages/svelar",
    "lint": "npm run lint --workspaces --if-present",
    "release": "node scripts/publish-svelar.mjs",
    "release:dry-run": "node scripts/publish-svelar.mjs --dry-run --skip-validation",
    "smoke": "node scripts/release-smoke.mjs",
    "smoke:ddd": "node scripts/release-smoke.mjs --app ddd",
    "smoke:flat": "node scripts/release-smoke.mjs --app flat",
    "smoke:fast": "node scripts/release-smoke.mjs --skip-shadcn --skip-tests --skip-build",
    "smoke:browser": "node scripts/release-smoke.mjs --app ddd --browser",
    "smoke:browser:headed": "node scripts/release-smoke.mjs --app ddd --browser --headed --slow-mo 350",
    "smoke:prod": "node scripts/release-smoke.mjs --app ddd --browser --prod",
    "smoke:db": "node scripts/release-smoke.mjs --app ddd --db all --services",
    "smoke:db:prod": "node scripts/release-smoke.mjs --app ddd --db all --services --browser --prod",
    "smoke:redis": "node scripts/release-smoke.mjs --app ddd --db sqlite --redis --skip-shadcn --skip-build",
    "smoke:pdf": "node scripts/release-smoke.mjs --app ddd --db sqlite --gotenberg --skip-shadcn --skip-build",
    "smoke:search": "node scripts/release-smoke.mjs --app ddd --db sqlite --meilisearch --skip-shadcn --skip-build",
    "smoke:pgbouncer": "node scripts/release-smoke.mjs --app ddd --db postgres --pgbouncer --skip-shadcn --skip-build",
    "smoke:s3": "node scripts/release-smoke.mjs --app ddd --db sqlite --s3 --skip-shadcn --skip-build",
    "certify": "node scripts/certify-release.mjs",
    "certify:fast": "node scripts/certify-release.mjs --fast",
    "certify:inventory": "node scripts/certify-release.mjs --inventory"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "version": "0.0.1"
}
